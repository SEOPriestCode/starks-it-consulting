  <section style="padding:60px 5% 0">
    <!-- FEATURED ARTICLE -->
    <div class="blog-featured" data-reveal>
      <div class="blog-feat-img">
        <img src="https://images.unsplash.com/photo-1544197150-b99a580bb7a8?w=900&q=80&auto=format&fit=crop" alt="Cloud migration strategy">
        <div class="img-overlay"></div>
      </div>
      <div class="blog-feat-body">
        <div class="blog-feat-label">Cloud Strategy</div>
        <div class="blog-feat-title">Why Nigerian Enterprises Are Getting Cloud Migration Wrong — and How to Fix It</div>
        <p class="blog-feat-excerpt">Too many organisations migrate to the cloud chasing cost savings, only to discover their bills have tripled within a year. We examine the five most common architectural mistakes and the engineering principles that prevent them — drawn from 40+ real migrations across West Africa.</p>
        <div class="blog-feat-meta">
          <span class="author-dot"></span>
          <span>Adaeze Emeka · CTO</span>
          <span>·</span>
          <span>12 April 2025</span>
          <span>·</span>
          <span style="font-family:var(--ff-mono)">8 min read</span>
        </div>
        <a class="arrow-btn" style="margin-top:1.5rem;display:inline-flex">Read Article →</a>
      </div>
    </div>

    <!-- ARTICLES GRID -->
    <div class="articles-grid">
      <div class="article-card" data-reveal>
        <div class="ac-img"><img src="https://images.unsplash.com/photo-1563986768494-4dee2763ff3f?w=600&q=80&auto=format&fit=crop" alt="Banking fintech AI data"></div>
        <div class="ac-body">
          <div class="ac-cat">Data & AI</div>
          <div class="ac-title">Building AI-Ready Data Pipelines for African Financial Institutions</div>
          <p class="ac-excerpt">The unique data quality, latency, and compliance challenges facing Nigerian fintechs — and the architecture patterns that address them at scale.</p>
          <div class="ac-meta">
            <span>Ngozi Okafor · 28 Mar 2025</span>
            <span class="ac-read">6 min →</span>
          </div>
        </div>
      </div>
      <div class="article-card" data-reveal data-delay="1">
        <div class="ac-img"><img src="https://images.unsplash.com/photo-1563013544-824ae1b704d3?w=600&q=80&auto=format&fit=crop" alt="Cybersecurity NDPR compliance"></div>
        <div class="ac-body">
          <div class="ac-cat">Compliance</div>
          <div class="ac-title">NDPR 2.0: What the New Regulations Mean for Your Technology Stack</div>
          <p class="ac-excerpt">A practical breakdown of the updated Nigeria Data Protection Regulation — and a prioritised remediation checklist for CIOs and CTOs to act on immediately.</p>
          <div class="ac-meta">
            <span>Tunde Fashola · 15 Mar 2025</span>
            <span class="ac-read">5 min →</span>
          </div>
        </div>
      </div>
      <div class="article-card" data-reveal data-delay="2">
        <div class="ac-img"><img src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&q=80&auto=format&fit=crop" alt="Digital transformation strategy meeting"></div>
        <div class="ac-body">
          <div class="ac-cat">Digital Transformation</div>
          <div class="ac-title">The CIO's Playbook for Leading Digital Transformation Without Losing the Organisation</div>
          <p class="ac-excerpt">Change management is where most transformation programmes fail. Here's the framework we use to bring people along — not just processes.</p>
          <div class="ac-meta">
            <span>Kola Balogun · 1 Mar 2025</span>
            <span class="ac-read">9 min →</span>
          </div>
        </div>
      </div>
      <div class="article-card" data-reveal>
        <div class="ac-img"><img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=80&auto=format&fit=crop" alt="ERP enterprise software implementation"></div>
        <div class="ac-body">
          <div class="ac-cat">Enterprise Software</div>
          <div class="ac-title">ERP Implementation in Africa: 7 Mistakes That Cost Organisations Millions</div>
          <p class="ac-excerpt">Custom ERP projects fail at an alarming rate. These are the seven root causes we've identified across 20+ implementations — and how to avoid each one.</p>
          <div class="ac-meta">
            <span>Emeka Okonkwo · 14 Feb 2025</span>
            <span class="ac-read">7 min →</span>
          </div>
        </div>
      </div>
      <div class="article-card" data-reveal data-delay="1">
        <div class="ac-img"><img src="https://images.unsplash.com/photo-1510511459019-5dda7724fd87?w=600&q=80&auto=format&fit=crop" alt="Zero trust cybersecurity network"></div>
        <div class="ac-body">
          <div class="ac-cat">Cybersecurity</div>
          <div class="ac-title">Zero Trust Is Not a Product — It's an Architecture. Here's How to Build It.</div>
          <p class="ac-excerpt">Most vendors will sell you "zero trust" in a box. Real zero trust is an organisational posture built layer by layer. This is the practical guide.</p>
          <div class="ac-meta">
            <span>Tunde Fashola · 28 Jan 2025</span>
            <span class="ac-read">11 min →</span>
          </div>
        </div>
      </div>
      <div class="article-card" data-reveal data-delay="2">
        <div class="ac-img"><img src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=600&q=80&auto=format&fit=crop" alt="Cloud infrastructure DevOps pipeline"></div>
        <div class="ac-body">
          <div class="ac-cat">Cloud Strategy</div>
          <div class="ac-title">FinOps in Practice: How We Cut a Client's AWS Bill by 58% Without Touching the Architecture</div>
          <p class="ac-excerpt">Cloud cost optimisation doesn't always require re-architecture. Sometimes it's about visibility, tagging hygiene, and reserved instance strategy. A real case study.</p>
          <div class="ac-meta">
            <span>Amaka Osei · 10 Jan 2025</span>
            <span class="ac-read">6 min →</span>
          </div>
        </div>
      </div>
      <div class="article-card" data-reveal>
        <div class="ac-img"><img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&q=80&auto=format&fit=crop" alt="Data warehouse analytics dashboard"></div>
        <div class="ac-body">
          <div class="ac-cat">Data & AI</div>
          <div class="ac-title">From Spreadsheets to Snowflake: A Practical Data Modernisation Roadmap</div>
          <p class="ac-excerpt">Most mid-market African companies are still running their analytics on Excel. Here's a realistic, phased path to a modern data stack — without the Silicon Valley price tag.</p>
          <div class="ac-meta">
            <span>Ngozi Okafor · 18 Dec 2024</span>
            <span class="ac-read">8 min →</span>
          </div>
        </div>
      </div>
      <div class="article-card" data-reveal data-delay="1">
        <div class="ac-img"><img src="https://images.unsplash.com/photo-1606761568499-6d2451b23c66?w=600&q=80&auto=format&fit=crop" alt="Public sector government digital services"></div>
        <div class="ac-body">
          <div class="ac-cat">Public Sector</div>
          <div class="ac-title">Digitising Government: Lessons from Nigeria's Most Successful e-Government Projects</div>
          <p class="ac-excerpt">After delivering three major government platforms, we've identified what separates successful public sector technology programmes from the ones that stall.</p>
          <div class="ac-meta">
            <span>Michael Omotayo · 2 Dec 2024</span>
            <span class="ac-read">10 min →</span>
          </div>
        </div>
      </div>
      <div class="article-card" data-reveal data-delay="2">
        <div class="ac-img"><img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=600&q=80&auto=format&fit=crop" alt="Team culture diversity technology Africa"></div>
        <div class="ac-body">
          <div class="ac-cat">Culture & Careers</div>
          <div class="ac-title">Building a World-Class Engineering Team in Lagos: What We've Learned in 10 Years</div>
          <p class="ac-excerpt">Talent density, compensation benchmarking, technical interviews, and retention — the honest version of what it takes to build and keep great engineers in Nigeria.</p>
          <div class="ac-meta">
            <span>Funke Adeyemi · 15 Nov 2024</span>
            <span class="ac-read">7 min →</span>
          </div>
        </div>
      </div>
    </div>

    <!-- NEWSLETTER -->
    <div class="newsletter-strip" data-reveal>
      <div>
        <div class="label"><div class="label-line"></div><span class="label-text">Stay Informed</span></div>
        <div class="nl-title">Get insights delivered to your inbox</div>
        <p class="nl-sub">New articles every two weeks. No spam, no fluff — just actionable technology intelligence for enterprise decision-makers.</p>
      </div>
      <div>
        <div class="nl-form">
          <input class="nl-input" type="email" placeholder="your@company.com">
          <button class="nl-btn">Subscribe</button>
        </div>
        <p style="font-size:0.72rem;color:var(--ash);margin-top:0.8rem;font-family:var(--ff-mono)">We respect your privacy. Unsubscribe anytime.</p>
      </div>
    </div>
  </section>

  <footer style="margin-top:80px">
    <div class="foot-grid">
      <div><div class="foot-brand-name">Starks <b style="color:var(--gold)">IT</b> Consulting</div><p class="foot-tagline">Enterprise technology consulting built for the African market and trusted globally.</p><div class="foot-certs"><span class="fc">ISO 27001</span><span class="fc">NITDA Reg.</span><span class="fc">AWS Partner</span></div></div>
      <div><div class="foot-col-h">Services</div><ul class="foot-links"><li><a onclick="showPage('services')">All Services</a></li><li><a onclick="showPage('services')">Custom Software</a></li><li><a onclick="showPage('services')">Cloud & DevOps</a></li></ul></div>
      <div><div class="foot-col-h">Company</div><ul class="foot-links"><li><a onclick="showPage('about')">About Us</a></li><li><a onclick="showPage('team')">Team</a></li><li><a onclick="showPage('cases')">Case Studies</a></li></ul></div>
      <div><div class="foot-col-h">Contact</div><ul class="foot-links"><li><a onclick="showPage('contact')">Get in Touch</a></li><li><a href="mailto:info@starks.com.ng">info@starks.com.ng</a></li><li><a href="tel:+2341234567890">+234 (0)123 456 7890</a></li></ul></div>
    </div>
    <div class="foot-bottom"><span class="foot-copy">© 2014–2025 Starks IT Consulting Ltd.</span><div class="foot-legal"><a href="#privacy">Privacy</a><a href="#terms">Terms</a><a href="#ndpr">NDPR</a></div></div>
  </footer>
</div>

<script>
// ── TOUCH DEVICE: hide custom cursor ──────────────────────
if('ontouchstart' in window){
  document.getElementById('cursor').style.display='none';
  document.getElementById('cursor-ring').style.display='none';
} else {
  document.body.style.cursor='none';
  const cursor=document.getElementById('cursor');
  const ring=document.getElementById('cursor-ring');
  let mx=0,my=0,rx=0,ry=0;
  document.addEventListener('mousemove',e=>{
    mx=e.clientX;my=e.clientY;
    cursor.style.left=mx+'px';cursor.style.top=my+'px';
  });
  // Cursor grow on interactive elements
  document.addEventListener('mouseover',e=>{
    if(e.target.closest('a,button,.hsvc,.case-card2,.article-card,.team-member,.hcase')){
      document.body.classList.add('cursor-hover');
    }
  });
  document.addEventListener('mouseout',e=>{
    if(e.target.closest('a,button,.hsvc,.case-card2,.article-card,.team-member,.hcase')){
      document.body.classList.remove('cursor-hover');
    }
  });
  (function animateRing(){
    rx+=(mx-rx)*0.12;ry+=(my-ry)*0.12;
    ring.style.left=Math.round(rx)+'px';ring.style.top=Math.round(ry)+'px';
    requestAnimationFrame(animateRing);
  })();
}

// ── SCROLL PROGRESS BAR (#13) ──────────────────────────────
const progressBar=document.getElementById('progress-bar');
function updateProgress(){
  const el=document.querySelector('.page.active');
  if(!el)return;
  const h=el.scrollHeight-window.innerHeight;
  progressBar.style.width=(h>0?(window.scrollY/h*100):0)+'%';
}
window.addEventListener('scroll',updateProgress,{passive:true});

// ── BACK TO TOP (#14) ─────────────────────────────────────
const backTop=document.getElementById('back-top');
window.addEventListener('scroll',()=>{
  backTop.classList.toggle('visible',window.scrollY>400);
  updateProgress();
},{passive:true});

// ── NAVBAR SCROLL SOLID ────────────────────────────────────
const nav=document.getElementById('nav');
window.addEventListener('scroll',()=>nav.classList.toggle('solid',window.scrollY>40),{passive:true});
if(window.scrollY>40)nav.classList.add('solid');

// ── HAMBURGER ─────────────────────────────────────────────
const hamburger=document.getElementById('hamburger');
const mobDrawer=document.getElementById('mob-drawer');
const mobOverlay=document.getElementById('mob-overlay');
hamburger.addEventListener('click',()=>{
  const open=mobDrawer.classList.toggle('open');
  mobOverlay.classList.toggle('open',open);
  hamburger.classList.toggle('open',open);
  document.body.style.overflow=open?'hidden':'';
});
function closeMobileNav(){
  mobDrawer.classList.remove('open');
  mobOverlay.classList.remove('open');
  hamburger.classList.remove('open');
  document.body.style.overflow='';
}

// ── PAGE TRANSITION CURTAIN (#12) ─────────────────────────
const curtain=document.getElementById('page-curtain');
let transitioning=false;
function runTransition(cb){
  if(transitioning)return;
  transitioning=true;
  curtain.classList.add('animating');
  // Swap page at midpoint (curtain fully covers screen)
  setTimeout(cb,330);
  curtain.addEventListener('animationend',()=>{
    curtain.classList.remove('animating');
    transitioning=false;
  },{once:true});
}

// ── PAGE ROUTER (#16 hash routing) ────────────────────────
const pages=['home','services','about','cases','team','blog','contact'];
function showPage(id,skipTransition=false){
  if(!document.getElementById('page-'+id))return;
  function doSwitch(){
    document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
    const target=document.getElementById('page-'+id);
    target.classList.add('active');
    window.scrollTo({top:0,behavior:'instant'});
    updateProgress();
    // nav highlights
    document.querySelectorAll('.nav-links a').forEach(a=>a.classList.toggle('active',a.dataset.page===id));
    document.querySelectorAll('[data-mob-page]').forEach(a=>a.classList.toggle('active',a.dataset.mobPage===id));
    // hash
    history.pushState({page:id},'','#'+id);
    // re-reveal
    setTimeout(()=>{
      target.querySelectorAll('[data-reveal]').forEach(el=>el.classList.remove('revealed'));
      observeReveals();
    },60);
  }
  if(skipTransition){doSwitch();}
  else{runTransition(doSwitch);}
}

// Hash routing on load (#16)
window.addEventListener('popstate',e=>{
  const id=(e.state&&e.state.page)||(location.hash.slice(1))||'home';
  if(pages.includes(id))showPage(id,true);
});
(function initFromHash(){
  const hash=location.hash.slice(1);
  const id=pages.includes(hash)?hash:'home';
  showPage(id,true);
})();

// ── SCROLL REVEAL ─────────────────────────────────────────
function observeReveals(){
  const obs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){e.target.classList.add('revealed');obs.unobserve(e.target);}
    });
  },{threshold:0.07,rootMargin:'0px 0px -30px 0px'});
  document.querySelectorAll('.page.active [data-reveal]').forEach(el=>{
    if(!el.classList.contains('revealed'))obs.observe(el);
  });
}
observeReveals();

// ── BLOG CATEGORY PILLS ───────────────────────────────────
document.querySelectorAll('.blog-cat-pill').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.blog-cat-pill').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
  });
});

// ── CASE STUDIES FILTER BUTTONS ───────────────────────────
document.querySelectorAll('.filter-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
  });
});

// ── FORM VALIDATION (#15) ─────────────────────────────────
const contactForm=document.getElementById('contact-form');
if(contactForm){
  contactForm.addEventListener('submit',function(e){
    e.preventDefault();
    let valid=true;
    function validate(fieldId,errId,checkFn){
      const el=document.getElementById(fieldId);
      const err=document.getElementById(errId);
      if(!el||!err)return;
      const ok=checkFn(el.value.trim());
      el.classList.toggle('form-error',!ok);
      err.classList.toggle('show',!ok);
      if(!ok)valid=false;
    }
    validate('f-fname','err-fname',v=>v.length>0);
    validate('f-lname','err-lname',v=>v.length>0);
    validate('f-email','err-email',v=>/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v));
    validate('f-company','err-company',v=>v.length>0);
    validate('f-service','err-service',v=>v!=='');
    validate('f-brief','err-brief',v=>v.length>10);
    if(valid){
      contactForm.style.display='none';
      document.getElementById('form-success').classList.add('show');
    }
  });
  // clear errors on input
  contactForm.querySelectorAll('input,select,textarea').forEach(el=>{
    el.addEventListener('input',()=>{
      el.classList.remove('form-error');
      const errId='err-'+el.id.replace('f-','');
      const err=document.getElementById(errId);
      if(err)err.classList.remove('show');
    });
  });
}
</script>
</body>
</html>
