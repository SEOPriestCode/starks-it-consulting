        <!-- SUCCESS STATE -->
        <div class="form-success" id="form-success">
          <span class="fs-icon">✓</span>
          <div class="fs-title">Message Received</div>
          <p class="fs-sub">Thank you for reaching out. A member of our team will be in touch within 4–8 business hours.<br><br>In the meantime, feel free to explore our <a onclick="showPage('cases')" style="color:var(--gold);cursor:pointer">case studies</a> or <a onclick="showPage('blog')" style="color:var(--gold);cursor:pointer">latest insights</a>.</p>
