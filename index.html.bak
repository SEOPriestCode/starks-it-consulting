            <input type="text" id="f-fname" placeholder="John">
            <span class="field-err" id="err-fname">Please enter your first name.</span>
          </div>
          <div class="fg">
            <label>Last Name</label>
            <input type="text" id="f-lname" placeholder="Doe">
            <span class="field-err" id="err-lname">Please enter your last name.</span>
          </div>
        </div>
        <div class="form-row">
          <div class="fg">
            <label>Email</label>
            <input type="email" id="f-email" placeholder="john@company.com">
            <span class="field-err" id="err-email">Please enter a valid email address.</span>
          </div>
          <div class="fg">
            <label>Phone</label>
            <input type="tel" id="f-phone" placeholder="+234 ...">
          </div>
        </div>
        <div class="fg">
          <label>Company</label>
          <input type="text" id="f-company" placeholder="Your company name">
          <span class="field-err" id="err-company">Please enter your company name.</span>
        </div>
        <div class="fg">
          <label>Service Required</label>
          <select id="f-service">
            <option value="">Select a service...</option>
            <option>Custom Software Development</option>
            <option>Cloud Infrastructure & DevOps</option>
            <option>Cybersecurity & Compliance</option>
            <option>Data Engineering & Analytics</option>
            <option>IT Strategy & Digital Transformation</option>
            <option>Managed IT Services</option>
            <option>Not sure — I need a consultation</option>
          </select>
          <span class="field-err" id="err-service">Please select a service.</span>
        </div>
        <div class="fg">
          <label>Estimated Budget</label>
          <select>
            <option value="">Select a range...</option>
            <option>Under $10,000</option>
            <option>$10,000 – $50,000</option>
            <option>$50,000 – $250,000</option>
            <option>$250,000+</option>
            <option>Prefer to discuss</option>
          </select>
        </div>
        <div class="fg">
          <label>Project Brief</label>
          <textarea id="f-brief" placeholder="Describe your challenge, goals, and any key timelines or constraints..."></textarea>
          <span class="field-err" id="err-brief">Please tell us a little about your project.</span>
        </div>
        <button type="submit" class="submit-btn"><span>Send Enquiry →</span></button>
        <p style="font-size:0.75rem;color:var(--ash);margin-top:1rem;text-align:center">All submissions are treated with strict confidentiality. We typically respond within 4–8 business hours.</p>
        </form>
      </div>
    </div>
  </div>
</div>

